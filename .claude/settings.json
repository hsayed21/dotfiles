{
  "permissions": {
    "allow": [
      "mcp__azureDevOps__get_*",
      "mcp__azureDevOps__list_*",
      "mcp__azureDevOps__search_*",
      "mcp__context7__*",
      "Bash(*)",
      "PowerShell(*)",
      "Read(*)",
      "Glob(*)",
      "WriteFile(*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "deny": [
      "Bash(*.git*)",
      "PowerShell(*.git*)",
      "Write(*.git*)",
      "Edit(*.git*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Read(.env)",
      "Read(**/.env)"
    ],
    "ask": [
      "mcp__azureDevOps__create_*",
      "mcp__azureDevOps__update_*",
      "mcp__azureDevOps__add_*",
      "Bash(rm *)",
      "Bash(git push *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git merge *)",
      "Bash(git reset *)",
      "Bash(git revert *)",
      "Bash(git clean *)",
      "Bash(git stash *)",
      "PowerShell(Remove-Item *)",
      "PowerShell(git push *)",
      "PowerShell(git add *)",
      "PowerShell(git commit *)",
      "PowerShell(git branch *)",
      "PowerShell(git merge *)",
      "PowerShell(git reset *)",
      "PowerShell(git revert *)",
      "PowerShell(git clean *)",
      "PowerShell(git stash *)"
    ]
  },
  "model": "opus",
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "pr-review@local": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "code-review@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {},
  "skipDangerousModePermissionPrompt": true
}
